      "Bash(./gradlew testDebugUnitTest assembleDebug --no-daemon)",
      "Bash(./gradlew bundleRelease)",
      "Bash(jarsigner -verify app/build/outputs/bundle/release/app-release.aab)",
      "Bash(git reset *)",
      "Bash(curl -fsSL -o gradlew.bat https://raw.githubusercontent.com/gradle/gradle/v8.14.0/gradlew.bat)",
