    <!-- Ajustes -->
    <string name="settings_title">Ajustes</string>
    <string name="sensitivity_title">Sensibilidad de detección</string>
    <string name="sensitivity_help">Un evento se registra cuando el sonido supera el ruido de fondo por este margen. Si duermes en un lugar ruidoso (calle transitada, ventilador fuerte) y se registran demasiados eventos, sube el valor; si se pierden ronquidos suaves, bájalo. Aplica a partir de la siguiente sesión.</string>
    <string name="sensitivity_value">+%1$d dB sobre el ruido de fondo</string>
    <string name="sensitivity_scale_hint">← más sensible (más eventos) · menos sensible (solo sonidos fuertes) →</string>
    <string name="sensitivity_floor_note">El ruido constante (un ventilador, la calle) se absorbe solo: el detector adapta su nivel de fondo automáticamente.</string>
    <string name="sensitivity_reset">Restablecer al valor recomendado (+%1$d dB)</string>

    <!-- Horario de sueño -->
    <string name="schedule_title">Horario de sueño</string>
    <string name="schedule_help">Detén —y si quieres, inicia— el monitoreo automáticamente a tus horas habituales.</string>
    <string name="schedule_enable">Programar horario</string>
    <string name="schedule_bedtime">Hora de dormir</string>
    <string name="schedule_wake">Hora de despertar</string>
    <string name="schedule_time_value">%1$02d:%2$02d</string>
    <string name="schedule_stop_note">El monitoreo se detiene solo cerca de tu hora de despertar (puede variar unos minutos para cuidar la batería). Si olvidas detenerlo, se cierra por ti.</string>
    <string name="schedule_autostart">Iniciar monitoreo automáticamente</string>
    <string name="schedule_autostart_help">Requiere haber concedido el permiso de micrófono al menos una vez. En algunos teléfonos el inicio puede tardar unos minutos.</string>
    <string name="schedule_exact_alarm_warning">Android no permite que Somnia programe alarmas exactas, y sin eso el monitoreo no puede arrancar solo a tu hora de dormir. Concede «Alarmas y recordatorios» para activarlo.</string>
    <string name="schedule_exact_alarm_action">Permitir alarmas exactas</string>
    <string name="schedule_alt_toggle">Horario distinto ciertos días</string>
    <string name="schedule_alt_help">Elige los días con otro horario (por ejemplo, el fin de semana). Cada día se refiere a la noche que empieza ese día: la noche del viernes termina el sábado por la mañana.</string>
    <string name="schedule_alt_wake">Despertar (esos días)</string>
