    <string name="settings_title">Ajustes</string>
    <string name="sensitivity_title">Sensibilidad de detección</string>
    <string name="sensitivity_help">Un evento se registra cuando el sonido supera el ruido de fondo por este margen. Si duermes en un lugar ruidoso (calle transitada, ventilador fuerte) y se registran demasiados eventos, sube el valor; si se pierden ronquidos suaves, bájalo. Aplica a partir de la siguiente sesión.</string>
    <string name="sensitivity_value">+%1$d dB sobre el ruido de fondo</string>
    <string name="sensitivity_scale_hint">← más sensible (más eventos) · menos sensible (solo sonidos fuertes) →</string>
    <string name="sensitivity_floor_note">El ruido constante (un ventilador, la calle) se absorbe solo: el detector adapta su nivel de fondo automáticamente.</string>
    <string name="sensitivity_reset">Restablecer al valor recomendado (+%1$d dB)</string>

